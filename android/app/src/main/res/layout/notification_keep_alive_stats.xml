<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/keep_alive_left_top_label"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="82dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Sessions" />

        <TextView
            android:id="@+id/keep_alive_left_top_value"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="62dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="start"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="0" />

        <TextView
            android:id="@+id/keep_alive_top_separator"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="20dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="·" />

        <TextView
            android:id="@+id/keep_alive_right_top_label"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="62dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Time" />

        <TextView
            android:id="@+id/keep_alive_right_top_value"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="start"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="0m" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/keep_alive_left_bottom_label"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="82dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Distance" />

        <TextView
            android:id="@+id/keep_alive_left_bottom_value"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="62dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="start"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="0.0km" />

        <TextView
            android:id="@+id/keep_alive_bottom_separator"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="20dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="·" />

        <TextView
            android:id="@+id/keep_alive_right_bottom_label"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="62dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="Ascent" />

        <TextView
            android:id="@+id/keep_alive_right_bottom_value"
            style="@style/TextAppearance.Compat.Notification.Line2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="start"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="0m" />
    </LinearLayout>
</LinearLayout>
